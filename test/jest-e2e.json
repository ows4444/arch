{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@/cashe(|/.*)$": "<rootDir>/../libs/cashe/src/$1",
    "^@/database(|/.*)$": "<rootDir>/../libs/database/src/$1",
    "^@/queue(|/.*)$": "<rootDir>/../libs/queue/src/$1"
  }
}