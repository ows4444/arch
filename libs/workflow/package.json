{
  "name": "@ows4444/nest-workflow",
  "version": "0.1.0",
  "description": "A NestJS library for durable workflow orchestration: multi-step workflows with persisted state, automatic retries, compensation (sagas), signals, and child workflows, backed by TypeORM.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
