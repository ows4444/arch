NODE_ENV=development

PORT=3000
WORKER_PORT=3001

MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_DATABASE=app
MYSQL_USERNAME=app
MYSQL_PASSWORD=app
MYSQL_TIME_ZONE=UTC

MYSQL_SYNCHRONIZE=false
MYSQL_MIGRATIONS_RUN=true
MYSQL_REPLICA=false

REDIS_HOST=localhost
REDIS_PORT=6380

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

AUTH_JWT_SECRET=change-me-to-a-random-32-plus-character-secret
# AUTH_ACCESS_TOKEN_TTL_SECONDS=900
# AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# Comma-separated list of allowed browser origins, or "*" for any.
# CORS is disabled (no browser cross-origin access at all) when unset.
# CORS_ORIGIN=http://localhost:5173
